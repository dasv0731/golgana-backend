PORT=3001
NODE_ENV=development

# Auth fase 1: bearer token estático. En deploy se reemplaza por validador JWT (Cognito).
ADMIN_API_KEY=devkey-change-me
PUBLIC_API_KEY=

# CORS — orígenes permitidos para la app Angular admin (coma-separado)
CORS_ORIGINS=http://localhost:4200

# Storage backend (json | dynamo)
STORAGE_DRIVER=json
DATA_DIR=./data
